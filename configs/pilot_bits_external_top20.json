{
  "_comment": "Pilot study 3: 固定 top20 + external AE，只比较 bit budget（8 / 16 / 32）和少量代表策略。",
  "experiment_name": "pilot_bits_external_top20",
  "description": "Pilot experiment to compare different bit budgets under external AE encoding.",
  "seed": 42,
  "dataset": {
    "_comment": "固定 top20 子集，用同一批类比较不同 bit budget。",
    "npz_path": "dataset/my_validation_subset_810000samples_27.00s.npz",
    "waveform": {
      "waveform_length": 79,
      "center_index": 39,
      "align_mode": "min",
      "channel_selection": "max_abs",
      "fixed_channel": 0
    },
    "subset": {
      "mode": "topk",
      "topk": 20
    },
    "sampling": {
      "_comment": "每个 unit 最多取 250 个 spikes，先做 pilot 级别的 bits 对照。",
      "max_total_spikes": null,
      "max_spikes_per_unit": 250,
      "selection_mode": "uniform_time"
    },
    "sort_by_time": true
  },
  "encoder": {
    "_comment": "base 是 external AE 16-bit；variants 会覆盖 code_size 和必要层数。",
    "method": "ae",
    "backend": "external",
    "code_size": 16,
    "cache_dir": "results/cache/encoded_cache",
    "reuse_cache": true,
    "force_reencode": false,
    "fit_scope": "all",
    "ae_type": "normal",
    "epochs": 3,
    "layers": [64, 32],
    "scale": "minmax",
    "learning_rate": 0.001,
    "batch_size": 128,
    "binarize_threshold": 0.0,
    "verbose": 0
  },
  "template_init": {
    "_comment": "bits 消融先固定 majority_vote。",
    "method": "majority_vote",
    "stable_mask_threshold": 0.85,
    "multi_template_per_unit": 2
  },
  "matcher": {
    "_comment": "threshold 会随 code_size 改变，所以各 variant 会覆盖合适阈值。",
    "method": "hamming_nearest",
    "threshold": 4.0,
    "min_margin": 2.0,
    "min_accept_margin": 1.0
  },
  "update": {
    "_comment": "base 是 static；bits 消融只带一个代表性的动态策略 CounterUpdate。",
    "method": "none",
    "max_confidence": 12,
    "alpha": 0.05,
    "lr": 0.15,
    "max_conf": 5.0,
    "min_weight": 0.25,
    "flip_threshold": 0.9,
    "split_threshold": 6.0,
    "margin_band": 1.0,
    "cooldown_steps": 50,
    "min_margin": 2.0,
    "allow_evict": false
  },
  "cam": {
    "_comment": "给动态策略和更高 bit 数留一点容量余量。",
    "capacity": null,
    "capacity_factor": 1.5,
    "extra_rows": 6,
    "eviction_policy": "least_used"
  },
  "evaluation": {
    "_comment": "chronological 是主评估口径。",
    "mode": "chronological",
    "warmup_ratio": 0.25,
    "random_train_frac": 0.7,
    "window_size": 250,
    "store_curves": true
  },
  "results": {
    "_comment": "保存完整结果，便于后续画 bits 对照图。",
    "results_dir": "results",
    "save_predictions": true,
    "save_curves": true,
    "save_confusion": true,
    "copy_encoded_dataset": false
  },
  "variants": [
    {
      "_comment": "8-bit static baseline。低 bit budget，threshold 也相应更低。",
      "name": "bits8_static",
      "encoder": {
        "code_size": 8,
        "layers": [48, 24]
      },
      "matcher": {
        "threshold": 2.0
      }
    },
    {
      "_comment": "8-bit + CounterUpdate。",
      "name": "bits8_counter",
      "encoder": {
        "code_size": 8,
        "layers": [48, 24]
      },
      "matcher": {
        "threshold": 2.0
      },
      "update": {
        "method": "counter"
      }
    },
    {
      "_comment": "16-bit static baseline。",
      "name": "bits16_static"
    },
    {
      "_comment": "16-bit + CounterUpdate。",
      "name": "bits16_counter",
      "update": {
        "method": "counter"
      }
    },
    {
      "_comment": "32-bit static baseline。更高维度需要更高 threshold。",
      "name": "bits32_static",
      "encoder": {
        "code_size": 32,
        "layers": [96, 48]
      },
      "matcher": {
        "threshold": 8.0
      }
    },
    {
      "_comment": "32-bit + CounterUpdate。",
      "name": "bits32_counter",
      "encoder": {
        "code_size": 32,
        "layers": [96, 48]
      },
      "matcher": {
        "threshold": 8.0
      },
      "update": {
        "method": "counter"
      }
    }
  ]
}
