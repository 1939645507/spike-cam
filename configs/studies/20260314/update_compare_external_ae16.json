{
  "_comment": "Study 2: compare dynamic update strategies under stream top50 / memory top20.",
  "experiment_name": "update_compare_external_ae16",
  "description": "Dynamic update strategy comparison under the memory-aware protocol.",
  "seed": 42,
  "dataset": {
    "npz_path": "dataset/my_validation_subset_810000samples_27.00s.npz",
    "waveform": {
      "waveform_length": 79,
      "center_index": 39,
      "align_mode": "min",
      "channel_selection": "max_abs",
      "fixed_channel": 0
    },
    "subset": {
      "mode": "topk",
      "topk": 50
    },
    "sampling": {
      "max_total_spikes": null,
      "max_spikes_per_unit": 250,
      "selection_mode": "uniform_time"
    },
    "sort_by_time": true
  },
  "encoder": {
    "method": "ae",
    "backend": "external",
    "code_size": 16,
    "cache_dir": "results/cache/encoded_cache",
    "reuse_cache": true,
    "force_reencode": false,
    "fit_scope": "all",
    "ae_type": "normal",
    "epochs": 3,
    "layers": [64, 32],
    "scale": "minmax",
    "learning_rate": 0.001,
    "batch_size": 128,
    "binarize_threshold": 0.0,
    "verbose": 0
  },
  "template_init": {
    "method": "majority_vote",
    "stable_mask_threshold": 0.85,
    "multi_template_per_unit": 2
  },
  "matcher": {
    "method": "hamming_nearest",
    "threshold": 4.0,
    "min_margin": 2.0,
    "min_accept_margin": 1.0
  },
  "update": {
    "method": "none",
    "max_confidence": 12,
    "alpha": 0.05,
    "lr": 0.15,
    "max_conf": 5.0,
    "min_weight": 0.25,
    "flip_threshold": 0.9,
    "split_threshold": 6.0,
    "margin_band": 1.0,
    "cooldown_steps": 50,
    "min_margin": 2.0,
    "allow_evict": false
  },
  "cam": {
    "capacity": null,
    "capacity_factor": 2.0,
    "extra_rows": 12,
    "eviction_policy": "least_used",
    "memory_subset": {
      "mode": "topk",
      "topk": 20,
      "selection_source": "pre_sampling"
    }
  },
  "evaluation": {
    "mode": "chronological",
    "warmup_ratio": 0.25,
    "random_train_frac": 0.7,
    "window_size": 250,
    "store_curves": true
  },
  "results": {
    "results_dir": "results/2026-03-14_full_study",
    "save_predictions": true,
    "save_curves": true,
    "save_confusion": true,
    "copy_encoded_dataset": false
  },
  "variants": [
    { "name": "static" },
    { "name": "counter", "update": { "method": "counter" } },
    { "name": "margin_ema", "update": { "method": "margin_ema", "alpha": 0.05, "margin_band": 1.0 } },
    { "name": "confidence_weighted", "matcher": { "method": "weighted_hamming", "threshold": 4.0 }, "update": { "method": "confidence_weighted", "lr": 0.15 } },
    { "name": "dual_template", "update": { "method": "dual_template", "alpha": 0.08 } },
    { "name": "probabilistic", "update": { "method": "probabilistic", "alpha": 0.05 } },
    { "name": "cooldown", "update": { "method": "cooldown", "alpha": 0.05, "cooldown_steps": 50 } },
    { "name": "top2_margin", "update": { "method": "top2_margin", "alpha": 0.05, "min_margin": 2.0 } },
    { "name": "growing", "update": { "method": "growing", "split_threshold": 6.0, "allow_evict": false } }
  ]
}
