{
  "_comment": "诊断配置：尽量贴近 previous work 的小规模 closed-set PCA baseline，用来判断问题更像是前端还是 open-set 协议。",
  "experiment_name": "diagnostics_top10_pca_closed",
  "description": "Diagnostic closed-set top10 experiment with PCA encoder.",
  "seed": 42,
  "dataset": {
    "npz_path": "dataset/my_validation_subset_810000samples_27.00s.npz",
    "preprocess": {
      "bandpass_enable": true,
      "bandpass_low_hz": 300.0,
      "bandpass_high_hz": 6000.0,
      "bandpass_order": 3,
      "common_reference_enable": true,
      "common_reference_mode": "median",
      "whitening_enable": false,
      "whitening_num_samples": 20000,
      "whitening_chunk_size": 50000,
      "whitening_eps": 1e-5
    },
    "waveform": {
      "waveform_length": 79,
      "center_index": 39,
      "align_mode": "min",
      "alignment_reference": "global_activity",
      "channel_selection": "topk_max_abs",
      "topk_channels": 8,
      "selection_radius": 8,
      "channel_order": "by_strength",
      "flatten_order": "channel_major",
      "fixed_channel": 0
    },
    "subset": {
      "mode": "topk",
      "topk": 10
    },
    "sampling": {
      "max_total_spikes": null,
      "max_spikes_per_unit": 300,
      "selection_mode": "uniform_time"
    },
    "sort_by_time": true
  },
  "encoder": {
    "method": "pca",
    "backend": "auto",
    "code_size": 16,
    "cache_dir": "results/cache/encoded_cache",
    "reuse_cache": true,
    "force_reencode": false,
    "fit_scope": "all",
    "scale": "robust",
    "binarize_threshold": 0.0,
    "verbose": 0
  },
  "template_init": {
    "method": "majority_vote",
    "stable_mask_threshold": 0.85,
    "multi_template_per_unit": 2
  },
  "matcher": {
    "method": "hamming_nearest",
    "threshold": 4.0,
    "min_margin": 2.0,
    "min_accept_margin": 1.0
  },
  "update": {
    "method": "none"
  },
  "cam": {
    "capacity": null,
    "capacity_factor": 1.0,
    "extra_rows": 0,
    "eviction_policy": "least_used"
  },
  "evaluation": {
    "mode": "chronological",
    "warmup_ratio": 0.25,
    "random_train_frac": 0.7,
    "window_size": 200,
    "store_curves": true
  },
  "results": {
    "results_dir": "results",
    "save_predictions": true,
    "save_curves": true,
    "save_confusion": true,
    "copy_encoded_dataset": false
  },
  "variants": [
    {
      "name": "static",
      "description": "Closed-set PCA static baseline."
    },
    {
      "name": "whiten_static",
      "description": "Closed-set PCA baseline with channel whitening enabled.",
      "dataset": {
        "preprocess": {
          "whitening_enable": true
        }
      }
    },
    {
      "name": "rawish_static",
      "description": "Closed-set PCA baseline without bandpass/CMR, for preprocessing diagnosis.",
      "dataset": {
        "preprocess": {
          "bandpass_enable": false,
          "common_reference_enable": false,
          "whitening_enable": false
        }
      }
    }
  ]
}
