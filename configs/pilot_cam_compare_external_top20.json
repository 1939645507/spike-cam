{
  "_comment": "Pilot study 2: 固定 top20 + external AE 16-bit，只比较几种代表性的 CAM update strategies。",
  "experiment_name": "pilot_cam_compare_external_top20",
  "description": "Pilot experiment to compare representative dynamic CAM update strategies under external AE encoding.",
  "seed": 42,
  "dataset": {
    "_comment": "固定 top20 子集，让主变化只来自 CAM 更新策略本身。",
    "npz_path": "dataset/my_validation_subset_810000samples_27.00s.npz",
    "waveform": {
      "waveform_length": 79,
      "center_index": 39,
      "align_mode": "min",
      "channel_selection": "max_abs",
      "fixed_channel": 0
    },
    "subset": {
      "mode": "topk",
      "topk": 20
    },
    "sampling": {
      "_comment": "每个 unit 最多取 250 个 spikes，保证 pilot 能较快完成。",
      "max_total_spikes": null,
      "max_spikes_per_unit": 250,
      "selection_mode": "uniform_time"
    },
    "sort_by_time": true
  },
  "encoder": {
    "_comment": "固定 external AE + 16-bit，避免把 encoder 差异和 CAM 差异混在一起。",
    "method": "ae",
    "backend": "external",
    "code_size": 16,
    "cache_dir": "results/cache/encoded_cache",
    "reuse_cache": true,
    "force_reencode": false,
    "fit_scope": "all",
    "ae_type": "normal",
    "epochs": 3,
    "layers": [64, 32],
    "scale": "minmax",
    "learning_rate": 0.001,
    "batch_size": 128,
    "binarize_threshold": 0.0,
    "verbose": 0
  },
  "template_init": {
    "_comment": "这里固定 majority_vote，初始化方法不在这个 pilot 里比较。",
    "method": "majority_vote",
    "stable_mask_threshold": 0.85,
    "multi_template_per_unit": 2
  },
  "matcher": {
    "_comment": "先固定最常用的 hamming_nearest。",
    "method": "hamming_nearest",
    "threshold": 4.0,
    "min_margin": 2.0,
    "min_accept_margin": 1.0
  },
  "update": {
    "_comment": "base update 配置，具体 variant 只覆盖 method 或少量关键参数。",
    "method": "none",
    "max_confidence": 12,
    "alpha": 0.05,
    "lr": 0.15,
    "max_conf": 5.0,
    "min_weight": 0.25,
    "flip_threshold": 0.9,
    "split_threshold": 6.0,
    "margin_band": 1.0,
    "cooldown_steps": 50,
    "min_margin": 2.0,
    "allow_evict": false
  },
  "cam": {
    "_comment": "给动态策略留一些扩容空间，避免过早被容量卡住。",
    "capacity": null,
    "capacity_factor": 1.5,
    "extra_rows": 6,
    "eviction_policy": "least_used"
  },
  "evaluation": {
    "_comment": "chronological online evaluation 是核心评估方式。",
    "mode": "chronological",
    "warmup_ratio": 0.25,
    "random_train_frac": 0.7,
    "window_size": 250,
    "store_curves": true
  },
  "results": {
    "_comment": "保留完整结果，方便比较 static 与动态策略的误更新和模板增长。",
    "results_dir": "results",
    "save_predictions": true,
    "save_curves": true,
    "save_confusion": true,
    "copy_encoded_dataset": false
  },
  "variants": [
    {
      "_comment": "静态模板对照组。",
      "name": "static",
      "description": "Static CAM baseline."
    },
    {
      "_comment": "CounterUpdate：更保守，bit flip 需要累积证据。",
      "name": "counter",
      "description": "Counter-based cautious update.",
      "update": {
        "method": "counter"
      }
    },
    {
      "_comment": "MarginEmaUpdate：只在接近 decision boundary 时更新。",
      "name": "margin_ema",
      "description": "EMA update only near the threshold.",
      "update": {
        "method": "margin_ema",
        "alpha": 0.05,
        "margin_band": 1.0
      }
    },
    {
      "_comment": "DualTemplateUpdate：模拟 stable template + plastic template 的思路。",
      "name": "dual_template",
      "description": "Stable/plastic dual-template update.",
      "update": {
        "method": "dual_template",
        "alpha": 0.08
      }
    }
  ]
}
