{
  "_comment": "初始化策略消融。固定 encoder 和 CAM 主框架，只比较模板初始化方式；stream 与 memory 分离。",
  "experiment_name": "init_ablation",
  "description": "Template initialization ablation under fixed encoder and CAM settings.",
  "seed": 42,
  "dataset": {
    "_comment": "这里的 subset 是进入编码/测试流的范围。",
    "npz_path": "dataset/my_validation_subset_810000samples_27.00s.npz",
    "preprocess": {
      "_comment": "初始化消融固定相同前处理，保证比较只聚焦 template init。",
      "bandpass_enable": true,
      "bandpass_low_hz": 300.0,
      "bandpass_high_hz": 6000.0,
      "bandpass_order": 3,
      "common_reference_enable": true,
      "common_reference_mode": "median",
      "whitening_enable": false,
      "whitening_num_samples": 20000,
      "whitening_chunk_size": 50000,
      "whitening_eps": 1e-5
    },
    "waveform": {
      "waveform_length": 79,
      "center_index": 39,
      "align_mode": "min",
      "alignment_reference": "global_activity",
      "channel_selection": "topk_max_abs",
      "topk_channels": 8,
      "selection_radius": 8,
      "channel_order": "by_strength",
      "flatten_order": "channel_major",
      "fixed_channel": 0
    },
    "subset": {
      "_comment": "测试流包含 top50 活跃类。",
      "mode": "topk",
      "topk": 50
    },
    "sampling": {
      "max_total_spikes": null,
      "max_spikes_per_unit": 250,
      "selection_mode": "uniform_time"
    },
    "sort_by_time": true
  },
  "encoder": {
    "method": "ae",
    "backend": "auto",
    "code_size": 16,
    "cache_dir": "results/cache/encoded_cache",
    "reuse_cache": true,
    "force_reencode": false,
    "fit_scope": "all",
    "ae_type": "normal",
    "epochs": 6,
    "layers": [64, 32],
    "scale": "robust",
    "learning_rate": 0.01,
    "batch_size": 128,
    "binarize_threshold": 0.0,
    "verbose": 1
  },
  "template_init": {
    "_comment": "base 初始化是 majority_vote；各 variant 会覆盖这里。",
    "method": "majority_vote",
    "stable_mask_threshold": 0.85,
    "multi_template_per_unit": 2
  },
  "matcher": {
    "method": "hamming_nearest",
    "threshold": 4.0,
    "min_margin": 2.0,
    "min_accept_margin": 1.0
  },
  "update": {
    "method": "none",
    "max_confidence": 12,
    "alpha": 0.05,
    "lr": 0.15,
    "max_conf": 5.0,
    "min_weight": 0.25,
    "flip_threshold": 0.9,
    "split_threshold": 6.0,
    "margin_band": 1.0,
    "cooldown_steps": 50,
    "min_margin": 2.0,
    "allow_evict": false
  },
  "cam": {
    "capacity": null,
    "capacity_factor": 1.5,
    "extra_rows": 4,
    "eviction_policy": "least_used",
    "memory_subset": {
      "_comment": "CAM 只记住 top20 类。",
      "mode": "topk",
      "topk": 20,
      "selection_source": "pre_sampling"
    }
  },
  "evaluation": {
    "mode": "chronological",
    "warmup_ratio": 0.25,
    "random_train_frac": 0.7,
    "window_size": 500,
    "store_curves": true
  },
  "results": {
    "results_dir": "results",
    "save_predictions": true,
    "save_curves": true,
    "save_confusion": true,
    "copy_encoded_dataset": false
  },
  "variants": [
    {
      "_comment": "majority_vote + static CAM。",
      "name": "majority_static",
      "template_init": { "method": "majority_vote" }
    },
    {
      "_comment": "medoid + static CAM。",
      "name": "medoid_static",
      "template_init": { "method": "medoid" }
    },
    {
      "_comment": "stable_mask + static CAM。",
      "name": "stable_mask_static",
      "template_init": { "method": "stable_mask", "stable_mask_threshold": 0.85 }
    },
    {
      "_comment": "majority_vote + CounterUpdate。",
      "name": "majority_counter",
      "template_init": { "method": "majority_vote" },
      "update": { "method": "counter" }
    },
    {
      "_comment": "medoid + CounterUpdate。",
      "name": "medoid_counter",
      "template_init": { "method": "medoid" },
      "update": { "method": "counter" }
    },
    {
      "_comment": "stable_mask + CounterUpdate。",
      "name": "stable_mask_counter",
      "template_init": { "method": "stable_mask", "stable_mask_threshold": 0.85 },
      "update": { "method": "counter" }
    }
  ]
}
